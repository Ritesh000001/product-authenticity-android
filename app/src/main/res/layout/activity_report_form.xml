<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#0F172A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Back -->
        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Report Product"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp" />

        <!-- Product Image -->
        <ImageView
            android:id="@+id/imgProduct"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:src="@drawable/ic_scan"
            android:scaleType="centerCrop" />

        <!-- Product Name -->
        <TextView
            android:id="@+id/txtProductName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="XYZ Shampoo"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <!-- Product ID -->
        <TextView
            android:id="@+id/txtProductId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Product ID: P001"
            android:textColor="#CBD5E1"
            android:textSize="14sp"
            android:layout_marginTop="6dp" />

        <!-- Manufacturer ID -->
        <TextView
            android:id="@+id/txtManufacturerId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manufacturer ID: "
            android:textColor="#CBD5E1"
            android:textSize="14sp"
            android:layout_marginTop="6dp" />

        <!-- Serial -->
        <TextView
            android:id="@+id/txtSerial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Serial: SN0001"
            android:textColor="#CBD5E1"
            android:textSize="14sp"
            android:layout_marginTop="6dp" />

        <!-- Status -->
        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Fake"
            android:textColor="#CBD5E1"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="6dp" />

        <!-- Reason Input -->
        <EditText
            android:id="@+id/etReason"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="20dp"
            android:background="@android:color/white"
            android:gravity="top"
            android:hint="Enter reason for report"
            android:padding="12dp"
            android:textColor="#000000"
            android:textColorHint="#6B7280" />

        <!-- Submit -->
        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Submit Report"
            android:layout_marginTop="20dp" />

    </LinearLayout>
</ScrollView>